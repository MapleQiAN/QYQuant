# Shared runtime settings
FLASK_ENV=development
SECRET_KEY=change-this-secret-key-in-production
JWT_SECRET=change-this-jwt-secret-in-production
FERNET_KEY=change-this-fernet-key-in-production
CORS_ORIGINS=http://localhost:58888

# Local developer URLs
DATABASE_URL=postgresql://qyquant:qyquant_password@localhost:5432/qyquant
REDIS_URL=redis://:redis_password@localhost:6379/0
CELERY_BROKER_URL=redis://:redis_password@localhost:6379/1
CELERY_RESULT_BACKEND=redis://:redis_password@localhost:6379/1

# Docker one-click deployment defaults
POSTGRES_USER=qyquant
POSTGRES_PASSWORD=qyquant_password
POSTGRES_DB=qyquant
POSTGRES_PORT=5432
REDIS_PASSWORD=redis_password
REDIS_PORT=6379
BACKEND_PORT=59999
FRONTEND_PORT=58888
GUNICORN_WORKERS=4
GUNICORN_TIMEOUT=120

# Backtest and market data
BACKTEST_DATA_PROVIDER=auto
BACKTEST_INTERVAL=1m
JOINQUANT_INTERVAL=1d
BINANCE_BASE_URL=https://api.binance.com
BINANCE_API_TIMEOUT=10
BINANCE_KLINE_CACHE_TTL=300
BINANCE_PRICE_CACHE_TTL=2
FREEGOLD_BASE_URL=https://freegoldapi.com
FREEGOLD_API_TIMEOUT=10
FREEGOLD_DATA_CACHE_TTL=21600
FREEGOLD_INTERVAL=1d
JQDATA_USERNAME=
JQDATA_PASSWORD=
JQDATA_REQUEST_TIMEOUT_SECONDS=3
JQDATA_MAX_RETRIES=2

# Auth and task processing
AUTH_FIXED_SMS_CODE=123456
AUTH_SMS_CODE_TTL=300
AUTH_SMS_THROTTLE_SECONDS=60
AUTH_SMS_MAX_FAILURES=5
AUTH_SMS_LOCK_SECONDS=1800
CELERYD_CONCURRENCY=10
CELERY_TASK_SOFT_TIME_LIMIT=300
CELERY_TASK_TIME_LIMIT=330
