{
  "schemaVersion": "1.0",
  "kind": "QYStrategy",
  "id": "ee1adc2c-2b67-4c9d-9c9f-b7c3a7d4ed85",
  "name": "黄金阶梯突破策略",
  "version": "1.0.0",
  "description": "基于前高突破和双重止损规则的黄金趋势跟踪示例。",
  "language": "python",
  "runtime": {
    "name": "python",
    "version": "3.11"
  },
  "entrypoint": {
    "path": "src/strategy.py",
    "callable": "on_bar",
    "interface": "event_v1"
  },
  "parameters": [
    {
      "key": "breakout_lookback",
      "type": "integer",
      "default": 20,
      "min": 5,
      "max": 300,
      "step": 1,
      "description": "突破判断使用的历史 K 线窗口长度。"
    },
    {
      "key": "drop_one_day_pct",
      "type": "number",
      "default": 3.0,
      "min": 0.5,
      "max": 20,
      "step": 0.1,
      "description": "单日跌幅止损阈值，单位为百分比。"
    },
    {
      "key": "drop_from_peak_pct",
      "type": "number",
      "default": 6.0,
      "min": 1,
      "max": 50,
      "step": 0.1,
      "description": "从持仓期最高点回撤的止损阈值，单位为百分比。"
    }
  ],
  "universe": {
    "symbols": ["XAUUSD"],
    "assetClass": "commodity",
    "market": "spot",
    "currency": "USD",
    "timezone": "UTC"
  },
  "data": {
    "resolution": "1d",
    "fields": ["open", "high", "low", "close", "volume"],
    "lookback": 60
  },
  "ui": {
    "category": "trend-following",
    "difficulty": "beginner"
  },
  "backtest": {
    "defaultPeriod": {
      "start": "2022-01-01",
      "end": "2025-12-31"
    },
    "initialCapital": 1000000
  },
  "tags": ["gold", "trend", "breakout", "beginner"]
}
