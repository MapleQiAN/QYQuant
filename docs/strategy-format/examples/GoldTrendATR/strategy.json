{
  "schemaVersion": "1.0",
  "kind": "QYStrategy",
  "id": "71f5b404-3152-4f2c-8d5a-d0665e65cf2d",
  "name": "Gold Trend ATR",
  "version": "1.0.0",
  "description": "Long-only gold breakout strategy with a trend filter, ATR-based trailing stop, and entry extension control.",
  "language": "python",
  "runtime": {
    "name": "python",
    "version": "3.11"
  },
  "entrypoint": {
    "path": "src/strategy.py",
    "callable": "on_bar",
    "interface": "event_v1"
  },
  "parameters": [
    {
      "key": "trend_sma_period",
      "type": "integer",
      "default": 60,
      "min": 20,
      "max": 250,
      "step": 1,
      "description": "Primary trend filter window."
    },
    {
      "key": "breakout_lookback",
      "type": "integer",
      "default": 20,
      "min": 10,
      "max": 120,
      "step": 1,
      "description": "Buy only when price closes above the previous breakout high."
    },
    {
      "key": "exit_ema_period",
      "type": "integer",
      "default": 12,
      "min": 3,
      "max": 60,
      "step": 1,
      "description": "Fast exit line for trend deterioration."
    },
    {
      "key": "atr_stop_multiplier",
      "type": "number",
      "default": 2.8,
      "min": 1.0,
      "max": 8.0,
      "step": 0.1,
      "description": "ATR multiple used for the trailing stop from the position peak."
    },
    {
      "key": "max_entry_extension_atr",
      "type": "number",
      "default": 1.2,
      "min": 0.2,
      "max": 5.0,
      "step": 0.1,
      "description": "Skip entries when the close is too far above the trend line in ATR units."
    },
    {
      "key": "position_pct",
      "type": "number",
      "default": 0.95,
      "min": 0.1,
      "max": 1.0,
      "step": 0.05,
      "description": "Share of available cash used for each entry."
    }
  ],
  "universe": {
    "symbols": ["XAUUSD"],
    "assetClass": "commodity",
    "market": "spot",
    "currency": "USD",
    "timezone": "UTC"
  },
  "data": {
    "resolution": "1d",
    "fields": ["open", "high", "low", "close", "volume"],
    "lookback": 160
  },
  "ui": {
    "category": "trend-following",
    "difficulty": "intermediate"
  },
  "backtest": {
    "defaultPeriod": {
      "start": "2020-01-01",
      "end": "2025-12-31"
    },
    "initialCapital": 1000000
  },
  "tags": ["gold", "xauusd", "trend", "breakout", "atr"]
}
