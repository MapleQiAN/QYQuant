{
  "schemaVersion": "1.0",
  "kind": "QYStrategy",
  "id": "a2e4a6cf-3f2f-4c5d-8a4a-1f5f9b2b2e10",
  "name": "黄金均线趋势策略",
  "version": "1.0.0",
  "description": "使用 SMA 过滤趋势并在突破近期高点后入场的黄金示例策略。",
  "language": "python",
  "runtime": {
    "name": "python",
    "version": "3.11"
  },
  "entrypoint": {
    "path": "src/strategy.py",
    "callable": "on_bar",
    "interface": "event_v1"
  },
  "parameters": [
    {
      "key": "trend_sma_period",
      "type": "integer",
      "default": 30,
      "min": 5,
      "max": 250,
      "step": 1,
      "description": "趋势过滤使用的简单移动平均窗口。"
    },
    {
      "key": "breakout_lookback",
      "type": "integer",
      "default": 20,
      "min": 5,
      "max": 250,
      "step": 1,
      "description": "突破判断使用的历史窗口长度。"
    },
    {
      "key": "max_drawdown_pct",
      "type": "number",
      "default": 6.0,
      "min": 1,
      "max": 30,
      "step": 0.1,
      "description": "从持仓高点回撤到该比例时执行卖出。"
    }
  ],
  "universe": {
    "symbols": ["XAUUSD"],
    "assetClass": "commodity",
    "market": "spot",
    "currency": "USD",
    "timezone": "UTC"
  },
  "data": {
    "resolution": "1d",
    "fields": ["open", "high", "low", "close", "volume"],
    "lookback": 120
  },
  "ui": {
    "category": "trend-following",
    "difficulty": "beginner"
  },
  "backtest": {
    "defaultPeriod": {
      "start": "2022-01-01",
      "end": "2025-12-31"
    },
    "initialCapital": 1000000
  },
  "tags": ["gold", "trend", "sma", "breakout"]
}
