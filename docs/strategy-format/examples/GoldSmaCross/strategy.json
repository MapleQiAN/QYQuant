{
  "schemaVersion": "1.0",
  "kind": "QYStrategy",
  "id": "9e7f5e9e-16c5-4fc7-9a07-41393efae3e4",
  "name": "Gold SMA Cross",
  "version": "1.0.0",
  "description": "Minimal daily XAUUSD moving-average crossover strategy for validating the current local backtest runtime.",
  "language": "python",
  "runtime": {
    "name": "python",
    "version": "3.11"
  },
  "entrypoint": {
    "path": "src/strategy.py",
    "callable": "Strategy",
    "interface": "event_v1"
  },
  "parameters": [
    {
      "key": "fast_period",
      "type": "integer",
      "default": 3,
      "min": 2,
      "max": 30,
      "step": 1,
      "description": "Fast moving average window."
    },
    {
      "key": "slow_period",
      "type": "integer",
      "default": 8,
      "min": 3,
      "max": 120,
      "step": 1,
      "description": "Slow moving average window."
    },
    {
      "key": "order_quantity",
      "type": "number",
      "default": 20.0,
      "min": 0.1,
      "max": 200.0,
      "step": 0.1,
      "description": "Fixed quantity used for each entry."
    }
  ],
  "universe": {
    "symbols": ["XAUUSD"],
    "assetClass": "commodity",
    "market": "spot",
    "currency": "USD",
    "timezone": "UTC"
  },
  "data": {
    "resolution": "1d",
    "fields": ["open", "high", "low", "close", "volume"],
    "lookback": 60
  },
  "ui": {
    "category": "trend-following",
    "difficulty": "beginner"
  },
  "backtest": {
    "defaultPeriod": {
      "start": "2024-10-01",
      "end": "2025-03-31"
    },
    "initialCapital": 100000
  },
  "tags": ["gold", "xauusd", "sma", "crossover", "starter"]
}
